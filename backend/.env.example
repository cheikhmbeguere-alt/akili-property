# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=property_management
DB_USER=prop_admin
DB_PASSWORD=PropMgt2024!

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@property-management.com
FROM_NAME=Property Management

# Pennylane API (optional for now)
PENNYLANE_API_KEY=

# INSEE API (for indices)
INSEE_API_ENABLED=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Cron Jobs
CRON_INDEXATION_ENABLED=true
CRON_QUITTANCES_ENABLED=true
CRON_RELANCES_ENABLED=true
RELANCE_DELAY_DAYS=7
